from Npp import *

# 1) Your mapping: exact old text -> new text
replacements = {
    # Examples – replace with your real pairs:
    "a = 10;": "a = 30;",
    "a = 20;": "a = 40;",
    # ...add all your mappings here
}

def apply_replacements_to_current():
    text = editor.getText()
    for old, new in replacements.items():
        text = text.replace(old, new)
    editor.setText(text)

apply_replacements_to_current()
